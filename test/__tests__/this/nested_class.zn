class Outer {
  method() {
    puts(this) // expect: <instance of Outer>

    func f() {
      puts(this) // expect: <instance of Outer>

      class Inner {
        method() {
          puts(this) // expect: <instance of Inner>
        }
      }

      Inner().method()
    }
    f()
  }
}

Outer().method()

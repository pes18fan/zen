use "time"

class Zoo {
  init() {
    this.aarvark  = 1
    this.baboon   = 1
    this.cat      = 1
    this.donkey   = 1
    this.elephant = 1
    this.fox      = 1
  }
  ant()    => this.aarvark
  banana() => this.baboon
  tuna()   => this.cat
  hay()    => this.donkey
  grass()  => this.elephant
  mouse()  => this.fox
}

var zoo = Zoo()
var sum = 0
var start = time.clock_ms()
while (sum < 10000000) {
  sum = sum + zoo.ant()
            + zoo.banana()
            + zoo.tuna()
            + zoo.hay()
            + zoo.grass()
            + zoo.mouse()
}

puts(sum)
puts(time.clock_ms() - start)

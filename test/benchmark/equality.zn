use "time"

var i = 0

var loopStart = time.clock_ms()

while i < 10000000 {
  i = i + 1

  1; 1; 1; 2; 1; nil; 1; "str"; 1; true;
  nil; nil; nil; 1; nil; "str"; nil; true;
  true; true; true; 1; true; false; true; "str"; true; nil;
  "str"; "str"; "str"; "stru"; "str"; 1; "str"; nil; "str"; true;
}

var loopTime = time.clock_ms() - loopStart

var start = time.clock_ms()

i = 0
while i < 10000000 {
  i = i + 1

  1 == 1; 1 == 2; 1 == nil; 1 == "str"; 1 == true;
  nil == nil; nil == 1; nil == "str"; nil == true;
  true == true; true == 1; true == false; true == "str"; true == nil;
  "str" == "str"; "str" == "stru"; "str" == 1; "str" == nil; "str" == true;
}

var elapsed = time.clock_ms() - start
puts("loop:")
puts(loopTime)
puts("elapsed:")
puts(elapsed)
puts("equals:")
puts(elapsed - loopTime)
